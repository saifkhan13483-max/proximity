modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
JWT_SECRET = "proximity_super_secret_jwt_key_2025_change_in_production"
NODE_ENV = "development"
PORT = "5000"
ALLOWED_ORIGIN = "*"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start Proximity"

[[workflows.workflow]]
name = "Start Proximity"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node proximity/backend/server.js"

[[ports]]
localPort = 5000
externalPort = 80
